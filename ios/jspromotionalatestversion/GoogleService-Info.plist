<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  IMPORTANT: Replace this file with the real GoogleService-Info.plist downloaded from the
  Firebase Console (https://console.firebase.google.com) for the "easyfllyer" project.

  Steps:
    1. Go to Firebase Console → Project Settings → Your apps → iOS app
    2. Download GoogleService-Info.plist
    3. Drag it into Xcode under the "jspromotionalatestversion" group (ensure
       "Copy items if needed" is checked and the target is "easy-flyer")
    4. Delete this placeholder file

  Without a valid GoogleService-Info.plist the app will crash at launch with:
  "Could not locate configuration file: 'GoogleService-Info.plist'"
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_WITH_REAL_VALUE</string>
	<key>REVERSED_CLIENT_ID</key>
