	<key>API_KEY</key>
	<string>REPLACE_WITH_REAL_VALUE</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_WITH_REAL_VALUE</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>REPLACE_WITH_REAL_BUNDLE_ID</string>
	<key>PROJECT_ID</key>
	<string>easyfllyer</string>
	<key>STORAGE_BUCKET</key>
	<string>easyfllyer.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
